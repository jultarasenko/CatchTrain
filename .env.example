# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Path (inside the container) to the SQLite database file
DATABASE_PATH=/data/subscriptions.db

# Separate Telegram bot used to send health-check alerts (own @BotFather token)
WATCHDOG_BOT_TOKEN=

# Telegram chat ID to receive watchdog alerts (e.g. your personal chat with the watchdog bot)
ALERT_CHAT_ID=
