# Route configuration
# Get station IDs by querying the UZ station search (see README "Finding station IDs")
STATION_ID_FROM=2200001
STATION_ID_TO=2218000

# Travel date in YYYY-MM-DD format
TRAVEL_DATE=2026-07-01

# Optional: only notify for these train numbers (comma-separated; leave empty to watch all trains on the route)
TRAIN_NUMBER=

# Minimum number of free seats to trigger a notification
MIN_SEATS=1

# How often to poll the UZ API, in seconds
CHECK_INTERVAL_SECONDS=60

# Telegram bot credentials (see README "Setting up Telegram")
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Path (inside the container) to the file used to trigger local sound alerts
SOUND_TRIGGER_PATH=/data/sound_trigger.json
